{
  "@timestamp": "{{ '@timestamp' }}",
  "ecs": { "version": "{{ ecs_version }}" },
  "event": {
    "kind": "event",
    "category": ["process"],
    "type": ["start"],
    "provider": "Microsoft-Windows-Security-Auditing",
    "code": "4688",
    "dataset": "windows.security",
    "module": "windows",
    "outcome": "success"
  },
  "host": {
    "name": "{{ host_name }}",
    "hostname": "{{ host_name }}",
    "domain": "{{ host_domain }}",
    "ip": ["{{ host_ip | default('10.0.0.1') }}"],
    "os": {
      "type": "windows",
      "platform": "windows",
      "family": "windows",
      "name": "Windows 10 Enterprise",
      "version": "10.0.19045"
    }
  },
  "user": {
    "name": "{{ user_name }}",
    "domain": "{{ user_domain }}",
    "id": "{{ user_sid | default('S-1-5-21-1234567890-1234567890-1234567890-1001') }}"
  },
  "agent": {
    "id": "{{ agent_id }}",
    "name": "{{ host_name }}",
    "type": "winlogbeat",
    "version": "{{ agent_version }}"
  },
  "process": {
    "pid": {{ process_pid }},
    "name": "{{ process_name }}",
    "executable": "{{ process_path | default(process_name) }}",
    "command_line": "{{ process_command_line | default(process_name) }}",
    "hash": {
      "sha256": "{{ process_hash_sha256 | default('') }}"
    },
    "parent": {
      "pid": {{ parent_pid | default(4) }},
      "name": "{{ parent_name | default('System') }}",
      "executable": "{{ parent_path | default('C:\\Windows\\System32\\' + (parent_name | default('System'))) }}"
    }
  },
  "winlog": {
    "provider_name": "Microsoft-Windows-Security-Auditing",
    "event_id": 4688,
    "channel": "Security",
    "computer_name": "{{ host_name }}.{{ host_domain }}",
    "record_id": {{ event_id | default(range(100000, 999999) | random) }},
    "keywords": ["Audit Success"],
    "task": "Process Creation",
    "opcode": "Info",
    "event_data": {
      "SubjectUserSid": "{{ user_sid | default('S-1-5-21-1234567890-1234567890-1234567890-1001') }}",
      "SubjectUserName": "{{ user_name }}",
      "SubjectDomainName": "{{ user_domain }}",
      "SubjectLogonId": "0x{{ range(100000, 999999) | random | string }}",
      "NewProcessId": "0x{{ '%x' % process_pid }}",
      "NewProcessName": {{ process_path | default(process_name) | tojson }},
      "TokenElevationType": "{{ '%%1938' if is_elevated | default(false) else '%%1936' }}",
      "ProcessId": "0x{{ '%x' % (parent_pid | default(4)) }}",
      "CommandLine": {{ process_command_line | default(process_name) | tojson }},
      "TargetUserSid": "S-1-0-0",
      "TargetUserName": "-",
      "TargetDomainName": "-",
      "TargetLogonId": "0x0",
      "ParentProcessName": {{ parent_path | default('C:\\Windows\\System32\\' + (parent_name | default('System'))) | tojson }},
      "MandatoryLabel": "S-1-16-8192"
    }
  },
  "log": { "level": "information" },
  "tags": ["attackchain", {% if is_noise | default(false) %}"noise"{% else %}"attack-simulation"{% endif %}],
  "labels": {
    "simulation": "attackchain",
    "is_noise": {{ is_noise | default(false) | tojson }}
  }
}
