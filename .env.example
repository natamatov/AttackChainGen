# ============================================================
# AttackChainGen — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=AttackChainGen
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-a-long-random-secret-key-32chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=attackchaindb
POSTGRES_USER=attackchain
POSTGRES_PASSWORD=strongpassword
DATABASE_URL=postgresql+asyncpg://attackchain:strongpassword@localhost:5432/attackchaindb

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Elasticsearch (default stand) ---
# These are overridden per-stand via the database
ELASTIC_URL=https://your-elastic-host:9200
ELASTIC_API_KEY=your-api-key-here
ELASTIC_INDEX_PREFIX=logs-attackchain

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- First Admin Account (created on first run) ---
ADMIN_EMAIL=admin@attackchain.local
ADMIN_PASSWORD=Admin1234!
